// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppUser {
  id        String   @id @default(uuid())
  fullName  String   @unique
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  passwordHash String?

  entries        WorkEntry[]
  absences       Absence[]
  monthlyTargets MonthlyTarget[]
}

model WorkEntry {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate  DateTime @db.Date
  startTime DateTime @db.Time
  endTime   DateTime @db.Time

  activity      String
  location      String
  distanceKm    Decimal @default(0)
  travelMinutes Int     @default(0)
  workMinutes   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workDate, startTime, endTime])
}

model Absence {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  absenceDate DateTime    @db.Date
  type        AbsenceType

  createdAt DateTime @default(now())

  @@unique([userId, absenceDate, type])
}

model MonthlyTarget {
  id            String @id @default(uuid())
  year          Int
  month         Int
  targetMinutes Int    @default(9600)

  userId String?
  user   AppUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([year, month, userId])
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum AbsenceType {
  VACATION
  SICK
}
