// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           String   @id @default(uuid())
  name         String
  subdomain    String   @unique
  logoUrl      String?
  primaryColor String?
  isDemo       Boolean  @default(false)
  createdAt    DateTime @default(now())

  users AppUser[]

  @@unique([name])
}

model AppUser {
  id                    String    @id @default(uuid())
  fullName              String
  role                  Role         @default(EMPLOYEE)
  language              AppLanguage  @default(DE)
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  passwordHash          String?
  passwordUpdatedAt     DateTime?
  missingEntriesStartAt DateTime?
  
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  entries                            WorkEntry[]
  dayBreaks                          DayBreak[]
  absences                           Absence[]
  absenceRequests                    AbsenceRequest[]
  decidedAbsenceRequests             AbsenceRequest[]             @relation("AbsenceRequestDecidedBy")
  monthlyTargets                     MonthlyTarget[]
  planEntries                        PlanEntry[]
  calendarEvents                     CalendarEvent[]
  dayNotes                           DayNote[]
  adminNotes                         AdminNote[]
  PasswordResetTokens                PasswordResetToken[]
  PasswordResetRequests              PasswordResetRequest[]
  googleCalendarConnections          GoogleCalendarConnection[]
  pushSubscriptions                  PushSubscription[]
  timeEntryCorrectionRequests        TimeEntryCorrectionRequest[]
  decidedTimeEntryCorrectionRequests TimeEntryCorrectionRequest[] @relation("TimeEntryCorrectionRequestDecidedBy")
  workEntryEditRequests             WorkEntryEditRequest[] @relation("WorkEntryEditRequestUser")
  decidedWorkEntryEditRequests      WorkEntryEditRequest[] @relation("WorkEntryEditRequestDecidedBy")
  timeEntryUnlocks                   TimeEntryUnlock[]
  tasks                              Task[]                       @relation("TaskAssignedTo")
  createdTasks                       Task[]                       @relation("TaskCreatedBy")
  completedTasks                     Task[]                       @relation("TaskCompletedBy")
  monthlyWorkEntryConfirmations      MonthlyWorkEntryConfirmation[] @relation("MonthlyWorkEntryConfirmationUser")
  targetedWorkEntryChangeReports WorkEntryChangeReport[] @relation("WorkEntryChangeReportTargetUser")
  createdWorkEntryChangeReports  WorkEntryChangeReport[] @relation("WorkEntryChangeReportChangedBy")

  // ✅ NEU: Upload-Relation
  uploadedPlanEntryDocuments PlanEntryDocument[] @relation("UploadedBy")

  @@unique([companyId, fullName])
  @@index([companyId])
}

model PasswordResetRequest {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    String    @default("OPEN") // "OPEN" | "DONE"
  createdAt DateTime  @default(now())
  doneAt    DateTime?

  @@index([userId])
  @@index([status])
}

model PasswordResetToken {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Wir speichern nur den HASH des Tokens (Sicherheitsbest practice)
  tokenHash String @unique

  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DayNote {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  noteDate DateTime @db.Date
  note     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, noteDate])
  @@index([userId, noteDate])
}

model CalendarEvent {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  startAt  DateTime
  endAt    DateTime
  location String?
  notes    String?
  titleSourceLanguage    AppLanguage?
  titleTranslations      Json?
  locationSourceLanguage AppLanguage?
  locationTranslations   Json?
  notesSourceLanguage    AppLanguage?
  notesTranslations      Json?

  // ===== Google Sync Felder =====
  googleEventId   String?   @unique
  googleICalUID   String?
  googleUpdatedAt DateTime?
  googleEtag      String?
  syncSource      String? // "APP" | "GOOGLE"
  lastSyncedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startAt])
}

model GoogleCalendarConnection {
  id     String  @id @default(uuid())
  userId String  @unique
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tokens (refreshToken MUSS bleiben, accessToken kannst du on-demand holen)
  refreshToken String
  calendarId   String @default("primary")

  // incremental sync
  syncToken String?

  // push channel (watch)
  channelId         String?
  resourceId        String?
  channelExpiration DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkEntry {
  id     String  @id @default(uuid())
  userId String
  noteEmployeeSourceLanguage AppLanguage?
  noteEmployeeTranslations Json?
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate  DateTime @db.Date
  startTime DateTime @db.Time
  endTime   DateTime @db.Time

  activity      String
  activitySourceLanguage AppLanguage?
  activityTranslations   Json?
  location      String
  locationSourceLanguage AppLanguage?
  locationTranslations   Json?
  distanceKm    Decimal @default(0)
  travelMinutes Int     @default(0)
  grossMinutes  Int     @default(0) // Brutto ohne Pause (Start-Ende)
  breakMinutes  Int     @default(0) // Pause in Minuten (manuell oder auto)
  breakAuto     Boolean @default(false) // true = automatisch abgezogen
  workMinutes   Int // Netto (Brutto - Pause)
  noteEmployee  String? // ✅ Notiz vom Mitarbeiter (für Admin sichtbar)

  changeReports WorkEntryChangeReport[]
  editRequests  WorkEntryEditRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workDate, startTime, endTime])
}

model WorkEntryChangeReport {
  id String @id @default(uuid())

  workEntryId String?
  workEntry   WorkEntry? @relation(fields: [workEntryId], references: [id], onDelete: SetNull)

  targetUserId String
  targetUser   AppUser @relation("WorkEntryChangeReportTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  changedByUserId String
  changedByUser   AppUser @relation("WorkEntryChangeReportChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  action WorkEntryChangeAction

  reason               String
  reasonSourceLanguage AppLanguage?
  reasonTranslations   Json?

  oldValues Json
  newValues Json?

  createdAt DateTime @default(now())

  @@index([workEntryId])
  @@index([targetUserId, createdAt])
  @@index([changedByUserId, createdAt])
  @@index([action])
}

model WorkEntryEditRequest {
  id String @id @default(uuid())

  userId String
  user   AppUser @relation("WorkEntryEditRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  workEntryId String
  workEntry   WorkEntry @relation(fields: [workEntryId], references: [id], onDelete: Cascade)

  requestedWorkDate      DateTime @db.Date
  requestedStartTime     DateTime @db.Time
  requestedEndTime       DateTime @db.Time
  requestedActivity      String
  requestedLocation      String
  requestedTravelMinutes Int      @default(0)
  requestedNoteEmployee  String?

  requestedActivitySourceLanguage AppLanguage?
  requestedActivityTranslations   Json?
  requestedLocationSourceLanguage AppLanguage?
  requestedLocationTranslations   Json?
  requestedNoteSourceLanguage     AppLanguage?
  requestedNoteTranslations       Json?

  reason               String
  reasonSourceLanguage AppLanguage?
  reasonTranslations   Json?

  status WorkEntryEditRequestStatus @default(PENDING)

  noteAdmin               String?
  noteAdminSourceLanguage AppLanguage?
  noteAdminTranslations   Json?

  decidedAt   DateTime?
  decidedById String?
  decidedBy   AppUser? @relation("WorkEntryEditRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([workEntryId])
  @@index([decidedById])
  @@index([status, createdAt])
}

model MonthlyWorkEntryConfirmation {
  id String @id @default(uuid())

  userId String
  user   AppUser @relation("MonthlyWorkEntryConfirmationUser", fields: [userId], references: [id], onDelete: Cascade)

  year  Int
  month Int

  status MonthlyWorkEntryConfirmationStatus @default(PENDING)

  confirmedAt DateTime?
  rejectedAt  DateTime?

  rejectionReason String?
  rejectionReasonSourceLanguage AppLanguage?
  rejectionReasonTranslations   Json?

  confirmationText String?
  confirmationTextSourceLanguage AppLanguage?
  confirmationTextTranslations   Json?

  entrySnapshot Json

  requiredUntilAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, status])
  @@index([year, month])
  @@index([requiredUntilAt])
}

model DayBreak {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate DateTime @db.Date

  breakStartHHMM String?
  breakEndHHMM   String?

  manualMinutes         Int @default(0)
  legalMinutes          Int @default(0)
  autoSupplementMinutes Int @default(0)
  effectiveMinutes      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workDate])
  @@index([userId, workDate])
}

model PlanEntry {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate      DateTime @db.Date
  startHHMM     String
  endHHMM       String
  activity      String
  activitySourceLanguage AppLanguage?
  activityTranslations   Json?
  location      String
  locationSourceLanguage AppLanguage?
  locationTranslations   Json?
  travelMinutes Int      @default(0)

  noteEmployee String?
  noteAdmin    String?
  noteEmployeeSourceLanguage AppLanguage?
  noteEmployeeTranslations   Json?
  noteAdminSourceLanguage    AppLanguage?
  noteAdminTranslations      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ NEU:
  documents PlanEntryDocument[]

  @@index([userId, workDate])
}

model PlanEntryDocument {
  id String @id @default(uuid())

  planEntryId String
  planEntry   PlanEntry @relation(fields: [planEntryId], references: [id], onDelete: Cascade)

  // Wer hat hochgeladen? (Admin)
  uploadedById String
  uploadedBy   AppUser @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  title     String
  fileName  String
  mimeType  String
  sizeBytes Int
  titleSourceLanguage AppLanguage?
  titleTranslations   Json?

  // ✅ Datei direkt in DB
  data Bytes

  createdAt DateTime @default(now())

  @@index([planEntryId])
  @@index([uploadedById])
}

model AdminNote {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate DateTime @db.Date
  note     String   @default("")
  noteSourceLanguage AppLanguage?
  noteTranslations   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workDate], name: "userId_workDate")
}

model Absence {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  absenceDate  DateTime            @db.Date
  type         AbsenceType
  dayPortion   AbsenceDayPortion   @default(FULL_DAY)
  compensation AbsenceCompensation @default(PAID)

  createdAt DateTime @default(now())

  @@unique([userId, absenceDate, type, dayPortion, compensation])
  @@index([userId, absenceDate])
}

model AbsenceRequest {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate    DateTime             @db.Date
  endDate      DateTime             @db.Date
  type         AbsenceType
  dayPortion   AbsenceDayPortion    @default(FULL_DAY)
  status       AbsenceRequestStatus @default(PENDING)
  compensation AbsenceCompensation  @default(PAID)
  
  paidVacationUnits   Int @default(0)
  unpaidVacationUnits Int @default(0)

  autoUnpaidBecauseNoBalance Boolean @default(false)
  compensationLockedBySystem Boolean @default(false)

  noteEmployee String?
  noteEmployeeSourceLanguage AppLanguage?
  noteEmployeeTranslations Json?

  decidedAt   DateTime?
  decidedById String?
  decidedBy   AppUser?  @relation("AbsenceRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, type])
  @@index([startDate, endDate])
  @@index([decidedById])
}

model MonthlyTarget {
  id            String @id @default(uuid())
  year          Int
  month         Int
  targetMinutes Int    @default(9600)

  userId String?
  user   AppUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([year, month, userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimeEntryCorrectionRequest {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  status       TimeEntryCorrectionRequestStatus @default(PENDING)
  noteEmployee String?
  noteAdmin    String?
  noteEmployeeSourceLanguage AppLanguage?
  noteEmployeeTranslations   Json?
  noteAdminSourceLanguage    AppLanguage?
  noteAdminTranslations      Json?

  decidedAt   DateTime?
  decidedById String?
  decidedBy   AppUser?  @relation("TimeEntryCorrectionRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  unlocks   TimeEntryUnlock[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId, status])
  @@index([startDate, endDate])
  @@index([decidedById])
}

model TimeEntryUnlock {
  id     String  @id @default(uuid())
  userId String
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  workDate DateTime @db.Date

  requestId String?
  request   TimeEntryCorrectionRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  expiresAt DateTime?
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workDate])
  @@index([userId, workDate])
  @@index([requestId])
}

model Task {
  id String @id @default(uuid())

  assignedToUserId String
  assignedToUser   AppUser @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: Cascade)

  createdByUserId String
  createdByUser   AppUser @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  completedByUserId String?
  completedByUser   AppUser? @relation("TaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  title       String
  description String?

  // 🔴 NEU:
  titleSourceLanguage AppLanguage?
  titleTranslations   Json?
  descriptionSourceLanguage AppLanguage?
  descriptionTranslations   Json?

  category       TaskCategory
  status         TaskStatus         @default(OPEN)
  requiredAction TaskRequiredAction @default(NONE)

  referenceDate      DateTime? @db.Date
  referenceStartDate DateTime? @db.Date
  referenceEndDate   DateTime? @db.Date
  dueAt              DateTime?
  completedAt        DateTime?

  completionNote               String?
  completionNoteSourceLanguage AppLanguage?
  completionNoteTranslations   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToUserId, status])
  @@index([assignedToUserId, category, status])
  @@index([createdByUserId])
  @@index([completedByUserId])
  @@index([referenceDate])
  @@index([referenceStartDate])
  @@index([referenceEndDate])
  @@index([dueAt])
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum AbsenceType {
  VACATION
  SICK
}

enum AbsenceDayPortion {
  FULL_DAY
  HALF_DAY
}

enum AbsenceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeEntryCorrectionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AbsenceCompensation {
  PAID
  UNPAID
}

enum TaskCategory {
  WORK_TIME
  VACATION
  SICKNESS
  GENERAL
}

enum TaskStatus {
  OPEN
  COMPLETED
}

enum TaskRequiredAction {
  NONE
  WORK_ENTRY_FOR_DATE
  VACATION_ENTRY_FOR_DATE
  SICK_ENTRY_FOR_DATE
  CONFIRM_MONTHLY_WORK_ENTRIES
}

enum AppLanguage {
  DE
  EN
  IT
  TR
  SQ
  KU
  RO
}

enum WorkEntryChangeAction {
  UPDATE
  DELETE
}

enum WorkEntryEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MonthlyWorkEntryConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
}